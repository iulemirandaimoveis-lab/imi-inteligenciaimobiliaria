# ===== DATABASE (Supabase PostgreSQL) =====
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ===== SUPABASE =====
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ===== AI APIS — Multi-LLM (Central de IA) =====

# Anthropic Claude — padrão para roteiros, copywriting, análise de lead
ANTHROPIC_API_KEY="sk-ant-api03-xxxxxxxxxxxxx"

# Google Gemini — geração de imagens (gemini-2.0-flash-exp), legendas, hashtags
GOOGLE_AI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXX"

# OpenAI GPT-4o — fallback para Claude em email/roteiro (OPCIONAL)
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# xAI Grok — análise de tendências em tempo real (OPCIONAL)
XAI_API_KEY="xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Azure OpenAI / GitHub Copilot Enterprise (OPCIONAL)
AZURE_OPENAI_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AZURE_OPENAI_ENDPOINT="https://seu-recurso.openai.azure.com"
AZURE_OPENAI_DEPLOYMENT="gpt-4o"

# Groq — inferência ultrarrápida Llama 3.3 (OPCIONAL, gratuito)
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google Cloud (OPCIONAL - para Vertex AI Imagen em produção)
# GOOGLE_CLOUD_PROJECT_ID="seu-projeto-id"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# ===== AUTHENTICATION =====
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# ===== APP CONFIG =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="IMI - Inteligência Imobiliária"

# ===== WHATSAPP (Opcional - para notificações) =====
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER=""

# ===== ANALYTICS (Opcional) =====
NEXT_PUBLIC_GA_ID=""

# ===== EMAIL (Opcional - para notificações) =====
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM=""

# ===== AGNO AI AGENTS (https://docs.agno.com) =====
# Serviço Python FastAPI com agentes especializados para o backoffice
# Início: cd agno && uvicorn main:app --reload --port 8001
AGNO_SERVICE_URL="http://localhost:8001"

# Agentes disponíveis em /backoffice/agno:
#   lead-qualifier      → Qualificação de leads (score, temperatura, follow-up)
#   property-copywriter → Descrições para portais, Instagram, WhatsApp
#   market-analyst      → Relatórios de mercado, precificação, tendências
#   content-strategist  → Conteúdo para redes sociais (usa GROQ_API_KEY)
#   real-estate-consultant → Consultoria, financiamento, jurídico básico
#   financial-analyst   → KPIs, metas, comissões, performance financeira
#   team (auto-routing) → Time completo que decide qual agente usar

# API Keys usadas pelo Agno service (já configuradas acima):
#   ANTHROPIC_API_KEY — Agentes principais (Claude Sonnet)
#   GROQ_API_KEY      — Agente de conteúdo (Llama 3.3, mais rápido)
#   OPENAI_API_KEY    — Fallback opcional
