# ============================================================================
# IMI — Inteligência Imobiliária
# Variáveis de ambiente para desenvolvimento local
# Copie este arquivo para .env.local e preencha os valores
# ============================================================================

# ── SUPABASE (obrigatório) ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://zocffccwjjyelwrgunhu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── SITE / APP (obrigatório) ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.iulemirandaimoveis.com.br
NEXT_PUBLIC_APP_URL=https://www.iulemirandaimoveis.com.br
NEXTAUTH_URL=https://www.iulemirandaimoveis.com.br

# ── IA / CLAUDE (obrigatório para funcionalidades de IA) ────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_API_KEY=                    # Alternativa ao ANTHROPIC_API_KEY
# OPENAI_API_KEY=                    # Para funcionalidades OpenAI (opcional)
# XAI_API_KEY=                       # Para X.AI/Grok (opcional)
# GOOGLE_AI_API_KEY=                 # Para Gemini (opcional)
# MOONDREAM_API_KEY=                 # Para análise de imagens (opcional)

# ── CRON JOBS (importante) ──────────────────────────────────────────────────
CRON_SECRET=your_cron_secret_here

# ── EMAIL / RESEND (importante para email transacional) ─────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@iulemirandaimoveis.com.br
RESEND_FROM_NAME=IMI — Iule Miranda Imóveis

# ── WHATSAPP / EVOLUTION API ────────────────────────────────────────────────
EVOLUTION_API_URL=https://your-evolution-instance.com
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE_NAME=imi-principal
# EVOLUTION_INSTANCE=               # Alias

# ── WHATSAPP / META BUSINESS (alternativo) ──────────────────────────────────
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=

# ── WHATSAPP / Z-API (alternativo) ─────────────────────────────────────────
# ZAPI_INSTANCE=
# ZAPI_TOKEN=
# ZAPI_CLIENT_ID=

# ── MAPBOX (mapa no site público) ───────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.ey...

# ── GOOGLE MAPS (Street View + Embed na página de detalhe) ─────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ── SENTRY (monitoramento de erros) ─────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_DSN=                        # Server-side DSN

# ── PUSH NOTIFICATIONS (PWA) ───────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=admin@iulemirandaimoveis.com.br

