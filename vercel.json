{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "installCommand": "npm install",
    "framework": "nextjs",
    "git": {
        "deploymentEnabled": {
            "youthful-fermi": false
        }
    },
    "github": {
        "autoJobCancelation": false
    },
    "regions": [
        "gru1"
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/cron/process-publishing-queue",
            "schedule": "0 1 * * *"
        },
        {
            "path": "/api/cron/process-email-sequences",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/cron/generate-weekly-reports",
            "schedule": "0 8 * * 1"
        },
        {
            "path": "/api/cron/process-follow-ups",
            "schedule": "0 9 * * *"
        }
    ]
}